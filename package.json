{
  "name": "claude-opt",
  "version": "0.1.0",
  "description": "Claude Code Token Optimizer — intelligent context management for Claude Code CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-opt": "./dist/index.js",
    "co": "./dist/index.js"
  },
  "files": [
    "dist",
    "starter-packs"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/"
  },
  "keywords": [
    "claude",
    "optimizer",
    "token",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
